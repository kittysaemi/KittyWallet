NODE_ENV=development
API_URL=http://localhost:5173/kittywallet/api/v1
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://kittywallet:kittywallet@localhost:5432/kittywallet?schema=public
JWT_SECRET=change-me-development-only
JWT_REFRESH_SECRET=change-me-development-only
