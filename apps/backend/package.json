{
  "name": "@kittywallet/backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "build": "prisma generate --schema prisma/schema.prisma && nest build",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema prisma/schema.prisma",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.cjs"
  },
  "dependencies": {
    "@kittywallet/shared-api": "0.1.0",
    "@kittywallet/shared-types": "0.1.0",
    "@nestjs/common": "^10.4.19",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.19",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.19",
    "@prisma/client": "^6.8.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "file-type": "^20.4.1",
    "heic-convert": "^2.1.0",
    "lucide-static": "^1.17.0",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.2",
    "tesseract.js": "^7.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.57",
    "@types/nodemailer": "^8.0.1",
    "jest": "^29.7.0",
    "prisma": "^6.8.2",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2"
  }
}
