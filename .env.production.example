NODE_ENV=production
API_URL=https://kittysaemi.com/kittywallet/api/v1
FRONTEND_URL=https://kittysaemi.com
DATABASE_URL=postgresql://kittywallet:replace-with-strong-password@postgres:5432/kittywallet?schema=public
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
PASSWORD_RESET_URL=https://kittysaemi.com/kittywallet/reset-password
SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=no-reply@kittysaemi.com
PWA_ENABLED=true
CACHE_VERSION=production-v1
SYNC_BATCH_SIZE=50
SYNC_RETRY_COUNT=3
POSTGRES_DB=kittywallet
POSTGRES_USER=kittywallet
POSTGRES_PASSWORD=replace-with-strong-password
KITTYWALLET_API_IMAGE=kittywallet-api:0.1.0
KITTYWALLET_WEB_IMAGE=kittywallet-web:0.1.0
